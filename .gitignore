```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.tsbuildinfo

# Environment
.env
.env.local
*.env.*

# Logs
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Python (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.coverage.*
.cache
.pytest_cache/
.mypy_cache/

# Node.js (if applicable)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled and build artifacts
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out
target/
.gradle/
```